PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bestinfra
# Optional startup retries for cloud DB warm-up/transient failures
DB_INIT_RETRIES=8
DB_INIT_RETRY_DELAY_MS=2000
# Optional: instead of DB_* keys, you can use DATABASE_URL or provider keys
# DATABASE_URL=mysql://user:pass@host:3306/database
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=*
